# Default: let git auto-detect text; do not force conversion
* text=auto

# ---- Scripts / code / config: CRLF ----
*.cs        text eol=crlf
*.shader    text eol=crlf
*.cginc     text eol=crlf
*.hlsl      text eol=crlf
*.compute   text eol=crlf
*.asmdef    text eol=crlf
*.asmref    text eol=crlf
*.json      text eol=crlf
*.xml       text eol=crlf
*.md        text eol=crlf
*.txt       text eol=crlf
*.uxml      text eol=crlf
*.uss       text eol=crlf
*.editorconfig text eol=crlf
*.gitattributes text eol=crlf
*.gitignore text eol=crlf

# ---- Shell scripts: LF (must stay LF to run) ----
*.sh        text eol=lf

# ---- Unity YAML assets: LF (Unity's native; avoids churn on save) ----
*.meta          text eol=lf
*.unity         text eol=lf
*.prefab        text eol=lf
*.asset         text eol=lf
*.mat           text eol=lf
*.anim          text eol=lf
*.controller    text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
