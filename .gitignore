# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
Rapier/.utmp/
/Rapier/[Ll]ibrary/
/Rapier/[Tt]emp/
/Rapier/[Oo]bj/
/Rapier/[Bb]uild/
/Rapier/[Bb]uilds/
/Rapier/[Ll]ogs/
/Rapier/[Uu]ser[Ss]ettings/
Rapier/*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
Rapier/*.blend1
Rapier/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/Rapier/[Mm]emoryCaptures/

# Recordings can get excessive in size
/Rapier/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/Rapier/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
Rapier/*.DotSettings.user

# Visual Studio cache directory
Rapier/.vs/

# Gradle cache directory
Rapier/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
Rapier/ExportedObj/
Rapier/.consulo/
Rapier/*.csproj
Rapier/*.unityproj
Rapier/*.sln
Rapier/*.suo
Rapier/*.tmp
Rapier/*.user
Rapier/*.userprefs
Rapier/*.pidb
Rapier/*.booproj
Rapier/*.svd
Rapier/*.pdb
Rapier/*.mdb
Rapier/*.opendb
Rapier/*.VC.db

# Unity3D generated meta files
Rapier/*.pidb.meta
Rapier/*.pdb.meta
Rapier/*.mdb.meta

# Unity3D generated file on crash reports
Rapier/sysinfo.txt

# Mono auto generated files
Rapier/mono_crash.*

# Builds
Rapier/*.apk
Rapier/*.aab
Rapier/*.unitypackage
Rapier/*.unitypackage.meta
Rapier/*.app

# Crashlytics generated file
Rapier/crashlytics-build.properties

# TestRunner generated files
Rapier/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/Rapier/ServerData
/Rapier/[Aa]ssets/StreamingAssets/aa*
/Rapier/[Aa]ssets/AddressableAssetsData/link.xml*
/Rapier/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/Rapier/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/Rapier/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/Rapier/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/Rapier/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/Rapier/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/Rapier/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Private repository (nested git repo with private assets: fonts, icons, etc.)
# Managed as a separate repo: github.com/miniron-v/Rapier-Private
/Rapier/Assets/Rapier-Private/